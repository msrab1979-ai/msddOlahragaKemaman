rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Sistem KOAM — tiada Firebase Auth dependency
    // Semua login guna sessionStorage (Pencatat, PP, Admin)
    // Firestore rules: read/write terbuka untuk fungsi sistem

    match /kejohanan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;

      match /acara/{aceraId} {
        allow read:   if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;

        match /heat/{heatId} {
          allow read:   if true;
          allow create: if true;
          allow update: if true;
          allow delete: if true;

          match /keputusan/{kId} {
            allow read:   if true;
            allow create: if true;
            allow update: if true;
            allow delete: if true;
          }
        }
      }

      match /pendaftaran/{noKP} {
        allow read:   if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }

      match /pengesahan/{kodSekolah} {
        allow read:   if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true;
      }
    }

    match /sekolah/{kodSekolah} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /atlet/{noKP} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /rekod/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /rekod_sejarah/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    match /rekod_tuntutan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /medal_tally/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /medal_tally_kat/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /mata_olahragawan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /pilihan_olahragawan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /log_reset/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    match /tetapan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /jadual_acara/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /users/{uid} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /kategori/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /bantahan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /pendaftaran_counter/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /login_attempts/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    match /anugerah_custom/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /wa_config/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
  }
}
