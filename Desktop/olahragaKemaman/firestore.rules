rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── NOTA KESELAMATAN ─────────────────────────────────────────────────────
    // Sistem ini guna PIN custom (bukan Firebase Auth) untuk log masuk.
    // Mitigasi R1(B): hadkan DELETE pada koleksi kritikal, buang wildcard catch-all.
    // Upgrade penuh perlu migrate ke Firebase Auth pada masa hadapan.

    // ─── Kejohanan + sub-koleksi ──────────────────────────────────────────────
    match /kejohanan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false; // padam kejohanan melalui Firebase Console sahaja

      match /acara/{aceraId} {
        allow read:   if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true; // admin boleh padam acara

        match /heat/{heatId} {
          allow read:   if true;
          allow create: if true;
          allow update: if true;
          allow delete: if true; // StartList boleh redo heat

          match /keputusan/{kId} {
            allow read:   if true;
            allow create: if true;
            allow update: if true;
            allow delete: if true;
          }
        }
      }

      match /pendaftaran/{noKP} {
        allow read:   if true;
        allow create: if true;
        allow update: if true;
        allow delete: if true; // pengurus boleh buang atlet
      }

      match /pengesahan/{kodSekolah} {
        allow read:   if true;
        allow create: if true;
        allow update: if true;
        allow delete: if false; // pengesahan kekal sebagai audit trail
      }
    }

    // ─── Sekolah ──────────────────────────────────────────────────────────────
    match /sekolah/{kodSekolah} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true; // admin boleh padam sekolah dari UI
    }

    // ─── Atlet ────────────────────────────────────────────────────────────────
    match /atlet/{noKP} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true; // reset sistem perlu padam atlet
    }

    // ─── Rekod — delete dibenar (ResetSistem admin padam rekod kejohanan) ────
    match /rekod/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true; // ResetSistem admin — upgrade ke Firebase Auth untuk hadkan
    }

    match /rekod_tuntutan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ─── Medal Tally — delete dibenar (ResetSistem admin perlu padam) ────────
    match /medal_tally/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true; // ResetSistem admin — upgrade ke Firebase Auth untuk hadkan
    }

    match /medal_tally_kat/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── Mata Olahragawan — delete dibenar (ResetSistem admin perlu padam) ───
    match /mata_olahragawan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true; // ResetSistem admin — upgrade ke Firebase Auth untuk hadkan
    }

    // ─── Pilihan Olahragawan — delete dibenar (ResetSistem admin perlu padam) ─
    match /pilihan_olahragawan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true; // ResetSistem admin — upgrade ke Firebase Auth untuk hadkan
    }

    // ─── Log Reset — audit trail reset sistem ────────────────────────────────
    match /log_reset/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if false;
      allow delete: if false; // audit trail kekal
    }

    // ─── Tetapan sistem ───────────────────────────────────────────────────────
    match /tetapan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ─── Jadual Acara ─────────────────────────────────────────────────────────
    match /jadual_acara/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── Pengguna sistem ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ─── Kategori ─────────────────────────────────────────────────────────────
    match /kategori/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── Bantahan — delete dibenar untuk ResetSistem admin ──────────────────
    match /bantahan/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true; // ResetSistem admin — upgrade ke Firebase Auth untuk hadkan
    }

    // ─── Pendaftaran Counter — noBib auto-increment per sekolah ─────────────────
    match /pendaftaran_counter/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false; // counter kekal sebagai audit trail
    }

    // ─── Login Attempts — rate limiting (R-NEW-3) ─────────────────────────────
    match /login_attempts/{id} {
      allow read:   if true;  // auth.js perlu baca sebelum semak
      allow create: if true;  // rekod pertama
      allow update: if true;  // kemas kini kiraan
      allow delete: if false; // rekod kekal sebagai audit trail
    }

    // ─── Anugerah Custom — admin cipta/padam anugerah khas kejohanan ─────────
    match /anugerah_custom/{id} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ─── TIADA wildcard catch-all ─────────────────────────────────────────────
    // Koleksi tidak tersenarai di atas = DITOLAK secara default.
    // Ini mencegah koleksi luar dijana oleh pihak yang tidak diketahui.
  }
}

